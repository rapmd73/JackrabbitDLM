# Most expensive part of the code, excluding disk operations. Making this global has
# doubled throughput. These two items are brutal in context of processing throughput.
# This is a reasonable trade-off for system stability and performance.

Process=psutil.Process(os.getpid())
# Total system RAM
TotalRAM=psutil.virtual_memory().total

# Memory threshold to rejecting new data stores, percentage

MemoryThreshold=33

# Statistics

Statistics={}

# Required global for the process to work

Locker={}

# Memory restrainst to optimize performance/stability. Reads this amount
# every call.

MaxBlockSize=4096

# Maximum TTL required to force authentication. This will also be the threshold
# for future persistent storage.

MaxTTL=3543

# Maximum megabytes allowed for the entire payload. Prevents memory exhaustion
# (leaching) from malicious/bad program. FUTURE CONSIDERATIONS: Limits differ
# per authenticated entries.

MaxPayloadSize=(10*1024*1024)   # 10 MB
MaxDataStoreSize=(16*1024)      # 16 K

# This will determine when to force a full gc collect based upon the
# memory actually deleted.

MaxDataHoldSize=0

# Encoding String, different order=different output, reasonable for a 10 second lock
ALPHABET='1aA2bB3cC4dD5eE6fF7gG8hH9iI0jJ!kK@lL#mM$nN%oO^pP&qQ*rR(sS)tT/uU?vV=wW+xX;yY:zZ'
BASELEN=len(ALPHABET)

# Pre-calculate for speed (O(1) lookups)
ENCODE_TABLE=[ALPHABET[b//BASELEN]+ALPHABET[b%BASELEN] for b in range(256)]
DECODE_TABLE={ALPHABET[b//BASELEN]+ALPHABET[b%BASELEN]: b for b in range(256)}

# Decode the input.  Just break the response if its bad data...

def dlmEncode(data_bytes):
    try:
        if isinstance(data_bytes, dict):
            data_bytes = json.dumps(data_bytes)
        if isinstance(data_bytes, str):
            data_bytes = data_bytes.encode('utf-8')
        return "".join(ENCODE_TABLE[b] for b in data_bytes)
    except:
        return b""

# Decode the input.  Just break the response if its bad data...

def dlmDecode(encoded_str):
    try:
        if not encoded_str:
            return b""
        return bytes(DECODE_TABLE[encoded_str[i:i+2]] for i in range(0, len(encoded_str), 2))
    except:
        return b""

# Check memory usage, return true is above threshold. This is expensive. The DLM
# literally has 3x the throughput WITHOUT this function.

def MemoryOverloadCheck(threshold_percent=MemoryThreshold):
    global Statistics
    global Process

    # Current process RAM usage
    process_ram=Process.memory_info().rss  # Resident Set Size in bytes

    # Percentage of total RAM used by this program
    usage_percent=(process_ram/TotalRAM)*100

    # Save the percentage statistics
    if usage_percent>Statistics.get('MemoryMax',0):
        Statistics['MemoryMax']=usage_percent
    Statistics['MemoryUsage']=usage_percent

    if usage_percent>threshold_percent:
        return True,usage_percent
    return False,usage_percent

# Sanitize file path for disk reading/writing

def Sanitize(FileName):
    fname=f"{DiskDirectory}/{dlmEncode(FileName)}.db"
    return fname

# Read authentication file from disk

def ReadIdentity(fn):
    fname=f"{ConfigDirectory}/{fn}.cfg"
    if os.path.exists(fname):
        cf=open(fname,'r')
        buffer=cf.read().strip()
        cf.close()
        try:
            buffer=json.loads(buffer)
        except Exception as err:
            buffer=None
        if buffer and 'Identity' in buffer and len(buffer['Identity'])<1023:
            buffer=None
    else:
        buffer=None
    if isinstance(buffer,dict) and 'MaxSize' not in buffer:
        buffer['MaxSize']=MaxDataStoreSize
    if isinstance(buffer,dict) and not NumberOnly(buffer['MaxSize']):
        buffer['MaxSize']=MaxDataStoreSize
    return buffer

# Write pid in port file

def WritePID(port):
    fn=LogDirectory+'/'+str(port)+'.pid'
    f=open(fn, "w")
    f.write(str(os.getpid()))
    f.close()

# Write log entry

def WriteLog(msg):
    time=(datetime.now().strftime('%Y-%m-%d %H:%M:%S.%f'))

    s=f'{time} {msg}\n'

    fh=open(LogDirectory+'/JackrabbitDLM.log','a')
    fh.write(s)
    fh.close()

def WriteError(err,addr,payload):
    id=secrets.token_urlsafe(73)
    fname=f"{QuarantineDirectory}/{id}.db"
    msg=f"DLMerror/{err}: {addr}/{fname}"
    WriteLog(msg)
    WriteFile(fname,json.dumps(payload))

# Write a file to disk

def WriteFile(fn,data):
    cf=open(fn,'w')
    cf.write(data)
    cf.close()

# Read a file from disk

def ReadFile(fn):
    if os.path.exists(fn):
        cf=open(fn,'r')
        buffer=cf.read().strip()
        cf.close()
    else:
        buffer=None
    return buffer

# Convience to build the status and a json payload

def jsonStatus(str,id=None,Tag=None,Data=None):
    res={}
    res['Status']=str

    if id!=None:
        res['ID']=id

    if Tag!=None and Data!=None:
        res[Tag]=Data

    out=dlmEncode(json.dumps(res))
    return out+'\n'

# Is it a number?

def NumberOnly(s):
    try:
        x=float(s)
        return True
    except:
        return False
    return False

# At startup, reload the disk files

def ReloadDiskMemory():
    global Locker
    global Statistics

    if not os.path.isdir(DiskDirectory):
        return

    # Loop through all files in the folder
    for FileName in os.listdir(DiskDirectory):
        fname=f"{DiskDirectory}/{FileName}"

        # Make sure is a file
        if not os.path.isfile(fname):
            continue

        # Ignore DOT files
        if FileName.startswith('.'):
            continue

        # Read the file on disk
        try:
            dataDB=json.loads(ReadFile(fname))
        except:
            Statistics['Corruption']=Statistics.get('Corruption',0)+1
            os.remove(fname)
            continue

        # If data is expired, do NOT reload it.

        if time.time()>dataDB['Expire']:
            Statistics['ExpiredData']=Statistics.get('ExpiredData', 0)+1
            os.remove(fname)
            continue

        # Set the Locker entry
        Locker[FileName]=dataDB
        Statistics['PutNew']=Statistics.get('PutNew',0)+1
        Statistics['DataIn']=Statistics.get('DataIn',0)+len(dataDB['DataStore'])
    return

# Check the authentication

def CheckIdentity(dataDB,LockDB):
    # If name is in one or the other, fail.

    if ('Name' in dataDB and 'Name' not in LockDB) \
    or ('Name' not in dataDB and 'Name' in LockDB):
        return False

    # if name is in locker, test REQUIRED.

    if 'Name' in LockDB:
        if 'Name' not in dataDB \
        or 'Identity' not in dataDB \
        or dataDB['Name']!=LockDB['Name'] \
        or dataDB['Identity']!=LockDB['Identity']:
            return False

    # No authentication needed
    return True

# Process the payload and carry out each of the desired functionalities.

# Lock and DataStore MUST be different. Unlock REMOVES data as the same.

def ProcessPayload(addr,data):
    global Statistics
    global Locker
    global MaxDataHoldSize

    # Build the data string from a list. Doing this here keep the memory "flushable".
    # This works because this is NOT the main function of the program. For a server,
    # keeping the main loop tight in python is critical.

    # Decode the payload
    data=dlmDecode(data.strip())

    try:
        dataDB=json.loads(data)
    except: # damaged payload
        Statistics['BadPayload']=Statistics.get('BadPayload',0)+1
        WriteError("Payload",addr,json.dumps(dataDB))
        return jsonStatus("BadPayload")

    # Find the lock

    # FileName and Action are required. For memory fetches, FileName is memory ID.

    if 'FileName' not in dataDB \
    or 'Action' not in dataDB \
    or 'ID' not in dataDB \
    or 'Expire' not in dataDB \
    or not NumberOnly(dataDB['Expire']):
        Statistics['BadPayload']=Statistics.get('BadPayload',0)+1
        WriteError("KeyVerify",addr,json.dumps(dataDB))
        return jsonStatus("BadPayload")

    dataDB['Expire']=float(dataDB['Expire'])

    # Verify any additional security layers. Identity is OPTIONAL, with the
    # following exceptions:
    #   1. Expiration > specified limit
    #   2. DataStore size > specified limit
    #
    # Checks:
    #   1. If "Name" is in the payload, then read the file (name.cfg)
    #   2. Verify "Identidy" string match. REQUIRED if
    #      "Name" is present.
    #
    # If veryify fails, return only BadPayload... No authentication leaking.
    #
    # If you are crazy enough to use authentication for a lock/data that lasts
    # seconds to minutes, then these requirements are nothing to worry about.
    #
    # Authentication REQUIRED for long term data storage.

    # Check the DataStore for this entrys

    # Check allowed anonymous size
    if 'DataStore' in dataDB and 'Name' not in dataDB:
        if dataDB['DataStore'] and len(dataDB['DataStore'])>MaxDataStoreSize:
            Statistics['AuthFailed']=Statistics.get('AuthFailed',0)+1
            WriteError("MaxDataStoreSize",addr,json.dumps(dataDB))
            return jsonStatus("BadPayload")

    # Force check expire
    if dataDB['Expire']>MaxTTL and 'Name' not in dataDB:
        Statistics['AuthFailed']=Statistics.get('AuthFailed',0)+1
        WriteError("MaxTTL",addr,json.dumps(dataDB))
        return jsonStatus("BadPayload")

    auth=None
    MaxSize=MaxDataStoreSize
    if 'Name' in dataDB:
        auth=ReadIdentity(dataDB['Name'])

        # All the ways it can fail.
        if auth is None \
        or 'Identity' not in dataDB \
        or 'Identity' not in auth \
        or len(dataDB['Identity'])<1023 \
        or dataDB['Identity']!=auth['Identity']:
            Statistics['AuthFailed']=Statistics.get('AuthFailed',0)+1
            WriteError("Identity",addr,json.dumps(dataDB))
            return jsonStatus("BadPayload")

        MaxSize=auth['MaxSize']

    # Valid actions:
    #   Lock
    #   Unlock
    #   Get
    #   Put
    #   Erase
    #   Version

    # With what we are doing. FileName also doubles as memory ID
    FileName=dataDB['FileName']
    action=dataDB['Action'].lower()

    # Handle the LOCK action. This allows an advisory locking method
    # that should work on any platform. Locking/Unlocking can be
    # used as a rate limiter as well.

    if action=='lock':
        # Check memory, if overloaded, nothing to that consumes more memory
        overload,pct=MemoryOverloadCheck()
        if overload:
            Statistics['MemoryOverloadCheck']=Statistics.get('MemoryOverloadCheck',0)+1
            return jsonStatus("NO")

        # New lock request
        if FileName not in Locker \
        or time.time()>Locker[FileName]['Expire']:
            dataLock={}
            dataLock['ID']=dataDB['ID']
            dataLock['Expire']=time.time()+dataDB['Expire']
            Locker[FileName]=dataLock
            if 'Name' in dataDB:    # Add the authentication
                Locker[FileName]['Name']=dataDB['Name']
                Locker[FileName]['Identity']=dataDB['Identity']
            Statistics['Lock']=Statistics.get('Lock',0)+1
            return jsonStatus("Locked",Locker[FileName]['ID'])

        # The current owner want the lock reset to a specific duration/held longer
        if Locker[FileName]['ID']==dataDB['ID']:
            if not CheckIdentity(dataDB,Locker[FileName]):
                # Lock access by a non-owner ID
                Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
                return jsonStatus("NotOwner")

            Locker[FileName]['Expire']=time.time()+dataDB['Expire']
            Statistics['Relock']=Statistics.get('Relock',0)+1
            return jsonStatus("Locked",Locker[FileName]['ID'])

        # Lock access by a non-owner ID
        Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
        return jsonStatus("NotOwner")
    # Unlock request
    elif action=='unlock':
        # Just pass through unlock
        if FileName not in Locker:
            Statistics['UnlockNF']=Statistics.get('UnlockNF',0)+1
            return jsonStatus("Unlocked")

        # Verify owner and unlock
        if Locker[FileName]['ID']==dataDB['ID']:
            if not CheckIdentity(dataDB,Locker[FileName]):
                # Lock access by a non-owner ID
                Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
                return jsonStatus("NotOwner")

            if Locker[FileName]['Expire']>0:
                Statistics['Unlock']=Statistics.get('Unlock',0)+1
            Locker[FileName]['Expire']=0
            return jsonStatus("Unlocked",Locker[FileName]['ID'])

        # Unock access by a non-owner ID. This may seem idiotic, but its an
        # absolute for keeping the lock from being hijacked.
        Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
        return jsonStatus("NotOwner")
    # Get memory reference
    elif action=='get':
        # Memory item doesn't exist
        if FileName not in Locker:
            Statistics['GetNF']=Statistics.get('GetNF',0)+1
            return jsonStatus("NotFound")

        # Verify owner of data
        if Locker[FileName]['ID']==dataDB['ID'] and time.time()<=Locker[FileName]['Expire']:
            if not CheckIdentity(dataDB,Locker[FileName]):
                # Lock access by a non-owner ID
                Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
                return jsonStatus("NotOwner")

            if 'DataStore' in Locker[FileName]:
                Statistics['Get']=Statistics.get('Get',0)+1
                Statistics['DataOut']=Statistics.get('DataOut',0)+len(Locker[FileName]['DataStore'])
                if 'Disk' in Locker[FileName]:
                    try:
                        data=json.loads(ReadFile(Sanitize(FileName)))
                        return jsonStatus("Done",Locker[FileName]['ID'],Tag="DataStore",Data=data['DataStore'])
                    except:
                        Statistics['Corruption']=Statistics.get('Corruption',0)+1
                        return jsonStatus("Corruption")
                return jsonStatus("Done",Locker[FileName]['ID'],Tag="DataStore",Data=Locker[FileName]['DataStore'])

            Statistics['GetNF']=Statistics.get('GetNF',0)+1
            return jsonStatus("NoData",Locker[FileName]['ID'])

        # Not the rightful owner
        Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
        return jsonStatus("NotOwner")
    elif action=='put':
        # Check memory, if overloaded, nothing to that consumes more memory
        overload,pct=MemoryOverloadCheck()
        if overload:
            Statistics['MemoryOverloadCheck']=Statistics.get('MemoryOverloadCheck',0)+1
            return jsonStatus("NO")

        # If there is no DataStore, its broke.
        if 'DataStore' not in dataDB:
            Statistics['BadPayload']=Statistics.get('BadPayload',0)+1
            return jsonStatus("BadPayload")

        # Optimize when to send to disk,

        ForceDisk=(len(dataDB['DataStore'])>MaxDataStoreSize and dataDB['Expire']>10) \
               or (len(dataDB['DataStore'])>MaxDataStoreSize and pct>(MemoryThreshold/2)) \
               or (len(dataDB['DataStore'])>MaxDataStoreSize/2 and pct>(MemoryThreshold*0.75))

        # New memory object
        if FileName not in Locker \
        or time.time()>Locker[FileName]['Expire']:
            # Force maximum size limit
            if len(dataDB['DataStore'])>MaxSize:
                Statistics['BadPayload']=Statistics.get('BadPayload',0)+1
                return jsonStatus("BadPayload")

            dStore={}
            dStore['ID']=dataDB['ID']
            dStore['Expire']=time.time()+dataDB['Expire']
            dStore['DataStore']=dataDB['DataStore']
            if ForceDisk:
                dStore['FileName']=FileName
                dStore['Disk']=True     # only pressence matters in Get()
            Locker[FileName]=dStore
            if 'Name' in dataDB:    # Add the authentication
                Locker[FileName]['Name']=dataDB['Name']
                Locker[FileName]['Identity']=dataDB['Identity']
            if 'Disk' in dStore:
                # Push to diskand shink memoet footprint. DataStore can NOT be removed
                # becaue of integrity testing.
                WriteFile(Sanitize(FileName),json.dumps(Locker[FileName]))
                Locker[FileName]['DataStore']="OD"
                Statistics['PutDisk']=Statistics.get('PutDisk',0)+1
            else:
                Statistics['PutMemory']=Statistics.get('PutMemory',0)+1
            Statistics['PutNew']=Statistics.get('PutNew',0)+1
            Statistics['DataIn']=Statistics.get('DataIn',0)+len(dataDB['DataStore'])
            return jsonStatus("Done",Locker[FileName]['ID'])

        # Existing memory object, verify owner and reset expiration timeout
        # Data is strange case. it is either erared or expired by main loop.
        if Locker[FileName]['ID']==dataDB['ID']:
            if not CheckIdentity(dataDB,Locker[FileName]):
                # Lock access by a non-owner ID
                Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
                return jsonStatus("NotOwner")

            # Force maximum size limit
            if len(dataDB['DataStore'])>MaxSize:
                Statistics['BadPayload']=Statistics.get('BadPayload',0)+1
                return jsonStatus("BadPayload")

            Locker[FileName]['DataStore']=dataDB['DataStore']
            # The DataStore can move back and forth from disk to memory.
            if ForceDisk:
                Locker[FileName]['FileName']=FileName
                Locker[FileName]['Disk']=True     # only pressence matters in Get()
            else:
                # Size under required limit, delete disk file.
                Locker[FileName].pop('Disk',None)
                if os.path.exists(Sanitize(FileName)):
                    os.remove(Sanitize(FileName))
            Locker[FileName]['Expire']=time.time()+dataDB['Expire']
            Locker[FileName]['DataStore']=dataDB['DataStore']
            if 'Disk' in Locker[FileName]:
                # Add the memory to the holding counter.
                MaxDataHoldSize+=len(Locker[FileName]['DataStore'])
                WriteFile(Sanitize(FileName),json.dumps(Locker[FileName]))
                Locker[FileName]['DataStore']="OD"
                Statistics['PutDisk']=Statistics.get('PutDisk',0)+1
            else:
                Statistics['PutMemory']=Statistics.get('PutMemory',0)+1

            Statistics['DataIn']=Statistics.get('DataIn',0)+len(dataDB['DataStore'])
            Statistics['PutUpdate']=Statistics.get('PutUpdate',0)+1
            return jsonStatus("Done",Locker[FileName]['ID'])

        # Not the rightful owner
        Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
        return jsonStatus("NotOwner")
    # Erase request
    elif action=='erase':
        # Just pass through erase
        if FileName not in Locker:
            Statistics['EraseNF']=Statistics.get('EraseNF',0)+1
            return jsonStatus("NotFound")

        # if NO DataStore, corrupted memory item...
        if 'DataStore' not in Locker[FileName]:
            Locker[FileName]['Expire']=0
            Statistics['Corruption']=Statistics.get('Corruption',0)+1
            return jsonStatus("Corruption")

        # Verify owner and erase memory. Erase is just resetting expiration to 0.
        # Will be remove in main function.
        if Locker[FileName]['ID']==dataDB['ID']:
            if not CheckIdentity(dataDB,Locker[FileName]):
                # Lock access by a non-owner ID
                Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
                return jsonStatus("NotOwner")

            Locker[FileName]['Expire']=0
            MaxDataHoldSize+=len(Locker[FileName]['DataStore'])
            Locker[FileName]['DataStore']=None
            Locker[FileName].pop('Disk',None)

            # I could test for 'Disk', but a DataStore can move back and forth from
            # disk to ram. The cost is minimal just to check the disk
            # (security/leakage).

            if os.path.exists(Sanitize(FileName)):
                os.remove(Sanitize(FileName))
            Statistics['Erased']=Statistics.get('Erased',0)+1
            return jsonStatus("Done",Locker[FileName]['ID'])

        # Not the rightful owner, fall thru
        Statistics['NotOwner']=Statistics.get('NotOwner',0)+1
        return jsonStatus("NotOwner")

    # get active version number
    elif action=='version':
        return jsonStatus("Version",f"JackrabbitDLM/{Version}")

    # Wrong key
    Statistics['BadAction']=Statistics.get('BadAction',0)+1
    return jsonStatus("BadAction")

###
### Main Driver
###

def main():
    global Statistics
    global Locker
    global MaxDataHoldSize

    # Create the needed directories

    os.makedirs(DiskDirectory,exist_ok=True)
    os.makedirs(LogDirectory,exist_ok=True)
    os.makedirs(QuarantineDirectory,exist_ok=True)

    OldHour=-1

    host=''
    port=37373

    if len(sys.argv) > 1:
        host=sys.argv[1]
    if len(sys.argv) > 2:
        port=int(sys.argv[2])

    WriteLog(f"Jackrabbit DLM {Version}")

    # Reload disk DataStores, if they are not expired.

    ReloadDiskMemory()

    # The length is a convience to keep the optimizations as high as possible.  Its
    # a slight of hand optimation from "+=" string concatination vs .append()/.join()
    # list operations. Difference is 9 seconds ("+=") compared to 0.06 seconds for
    # .append().join() for a 100 MB payload.

    dataStore={}

    # Sending buffer to handle large payloads effeciently.

    sendBuffer={}

    try:
        lockerSocket=socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        lockerSocket.setsockopt(socket.SOL_SOCKET,socket.SO_REUSEADDR,1)
        lockerSocket.setblocking(0)
        lockerSocket.bind((host, port))
        lockerSocket.listen(1024)
    except OSError as err:
        x=str(err)
        if 'Address already in use' in x:
            x='Another program is using this port: '+str(port)
        WriteLog(x)
        sys.exit(1)

    WritePID(port)

    poller=select.poll()
    fdmap={}
    addrmap={}

    poller.register(lockerSocket, select.POLLIN)
    fdmap[lockerSocket.fileno()]=lockerSocket

    try:
        while True:
            # 30 decond timeout for IDLE
            events=poller.poll(30000)

            if not events:
                # Idle phase
                Statistics['Idle']=Statistics.get('Idle', 0)+1
                if MaxDataHoldSize > MaxPayloadSize:
                    # Force GC to clean
                    Statistics['ForcedGC']=Statistics.get('ForcedGC', 0)+1
                    MaxDataHoldSize=0
                    gc.collect()

            # Track active in/out
            actin=0
            actout=0

            # Event loop
            for fd, event in events:
                fds=fdmap.get(fd)
                if fds is None:
                    continue

                # New connection
                if fds is lockerSocket:
                    try:
                        clientsock, clientaddr=fds.accept()
                        clientsock.setblocking(0)

                        poller.register(clientsock, select.POLLIN)
                        fdmap[clientsock.fileno()]=clientsock

                        addrmap[clientsock]=clientaddr[0] # fds -> cliendsock
                        dataStore[clientsock]=''          # MUST be initialized
                        Statistics['Connections']=Statistics.get('Connections', 0)+1
                    except:
                        continue

                # Read event
                elif event & select.POLLIN:
                    actin+=1
                    data=None
                    try:
                        data=fds.recv(MaxBlockSize)
                    except:
                        pass

                    if not data:
                        if fds in dataStore:
                            MaxDataHoldSize+=len(dataStore[fds])
                            dataStore.pop(fds, None)

                        if fds in sendBuffer:
                            sendBuffer.pop(fds, None)

                        poller.unregister(fds)
                        fdmap.pop(fd, None)
                        addrmap.pop(fd, None)
                        fds.close()
                        continue

                    # Enforce maximum payload size
                    if len(dataStore[fds])+len(data) > MaxPayloadSize:
                        MaxDataHoldSize+=len(dataStore[fds])
                        dataStore.pop(fds, None)
                        sendBuffer.pop(fds, None)

                        poller.unregister(fds)
                        fdmap.pop(fd, None)
                        addrmap.pop(fd, None)
                        fds.close()

                        Statistics['DataOverrun']=Statistics.get('DataOverrun', 0)+1
                        continue

                    # I don't want bad connections tracked
                    Statistics['In']=Statistics.get('In', 0)+1

                    try:
                        data=data.decode('utf-8')
                    except:
                        continue

                    dataStore[fds]+=data

                    if data.endswith('\n'):
                        response=ProcessPayload(addrmap[fds],dataStore[fds])
                        sendBuffer[fds]=response.encode('utf-8')
                        # Set up for sending answer
                        poller.modify(fds, select.POLLOUT)

                # Write event using send()
                elif event & select.POLLOUT:
                    actout+=1
                    if fds in sendBuffer:
                        try:
                            sent=fds.send(sendBuffer[fds])
                        except:
                            sent=0

                        if sent > 0:
                            sendBuffer[fds]=sendBuffer[fds][sent:]

                        # If all data sent, close connection (same behavior as original)
                        if not sendBuffer[fds]:
                            sendBuffer.pop(fds, None)

                            if fds in dataStore:
                                MaxDataHoldSize+=len(dataStore[fds])
                                dataStore.pop(fds, None)

                            poller.unregister(fds)
                            fdmap.pop(fd, None)
                            addrmap.pop(fd, None)
                            fds.close()

                            Statistics['Out']=Statistics.get('Out', 0)+1

                # Error / hangup
                elif event & (select.POLLHUP | select.POLLERR):
                    Statistics['BadConn']=Statistics.get('BadConn', 0)+1
                    if fds in dataStore:
                        MaxDataHoldSize+=len(dataStore[fds])
                        dataStore.pop(fds, None)

                    if fds in sendBuffer:
                        sendBuffer.pop(fds, None)

                    poller.unregister(fds)
                    fdmap.pop(fd, None)
                    addrmap.pop(fd, None)
                    fds.close()

            # Active in/out events
            Statistics['AIn']=actin
            Statistics['AOut']=actout

            # Cleanup expired locks/data and track only active locks/data
            Statistics['ALock']=0
            Statistics['AData']=0

            # Purge expired
            now=time.time()
            for k in list(Locker):
                # Search for expired data.  This is VERY fast when focusing on only 1
                # aspect. This cascading layer heps filter quickly what is NOT wanted.
                if now>Locker[k]['Expire']:
                    if 'DataStore' in Locker[k]:
                        if Locker[k]['DataStore'] is not None:
                            if 'Disk' in Locker[k]:
                                if os.path.exists(Sanitize(k)):
                                    os.remove(Sanitize(k))
                            MaxDataHoldSize+=len(Locker[k]['DataStore'])
                            Locker[k]['DataStore']=None
                        Statistics['ExpiredData']=Statistics.get('ExpiredData',0)+1
                    else:
                        Statistics['ExpiredLock']=Statistics.get('ExpiredLock',0)+1
                    Locker.pop(k, None)

                # Count the active enty only
                if k in Locker:
                    if 'DataStore' in Locker[k]:
                        Statistics['AData']+=1
                    else:
                        Statistics['ALock']+=1

            # Log the statistics
            if now-OldHour>3600 and len(Statistics)>0:
                OldHour=now
                MemoryOverloadCheck()
                s=', '.join(f"{k}: {v}" for k,v in sorted(Statistics.items()) if v>0)
                WriteLog(s)

                # Rebuild dictionaries to remove fragmentation.
                Locker=dict(Locker)
                dataStore=dict(dataStore)
                sendBuffer=dict(sendBuffer)
                fdmap=dict(fdmap)
                addrmap=dict(addrmap)
                Statistics={}

            # Check for a foced GC run. Keep the system as lean as possible.
            if MaxDataHoldSize>MaxPayloadSize:
                # Force GC to clean
                Statistics['ForcedGC']=Statistics.get('ForcedGC', 0)+1
                MaxDataHoldSize=0
                gc.collect()
    except Exception as err:
        print(err)
        # Try to catch everything and get the last bit of statstics.
        MemoryOverloadCheck()
        s=', '.join(f"{k}: {v}" for k,v in sorted(Statistics.items()) if v>0)
        WriteLog(s)

###
### Main driver
###

if __name__ == '__main__':
    main()

